{
  "model": "claude-sonnet-4-6",
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run build:renderer:*)",
      "Bash(npm run build:main:*)",
      "Bash(npm test:*)",
      "Bash(npm run preview:*)",
      "Bash(npx tsc --noEmit:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)"
    ]
  },
  "env": {
    "NODE_ENV": "development"
  }
}
