# AgentMesh development environment variables
# Copy this file to .env and fill in values as needed.
# Never commit .env — it is listed in .gitignore.

# Override the AgentMesh server URL used by the stdio MCP proxy.
# Only needed if you changed the default port (4321) in Settings.
# AGENTMESH_URL=http://127.0.0.1:4321

# API keys for cloud agent runners.
# In production the app stores these via Electron safeStorage (encrypted).
# In development you can set them here as a fallback.
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=
# HF_API_KEY=
